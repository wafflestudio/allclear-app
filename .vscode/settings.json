{
	"editor.detectIndentation": false,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"prettier.configPath": ".prettierrc.json",
	"prettier.useTabs": true,
	"prettier.tabWidth": 2,
	"[javascript]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 2
	},
	"[javascriptreact]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 2
	},
	"[typescript]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 2
	},
	"[typescriptreact]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 2
	},
	"files.associations": {
		"*.tsx": "typescriptreact",
		"*.yaml": "yaml",
		"*.html": "html",
		"*.css": "css",
		"*.md": "markdown",
		"*.json": "jsonc",
		"*.ts": "typescript",
		"*.feature": "feature",
		"*.ttml": "xml",
		"*.ttss": "css"
	}
}
